{
  "name": "stylistics-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "latest",
    "@types/node": "^25.4.0",
    "lefthook": "^2.1.4",
    "mastra": "^1.3.15"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "mastra dev",
    "build": "mastra build",
    "start": "mastra start",
    "lint": "biome check .",
    "lint:write": "biome check --write .",
    "format": "biome format --write .",
    "lint:staged": "biome check --staged --write --no-errors-on-unmatched",
    "check:filenames": "node scripts/check-file-naming.mjs",
    "validate": "bun run lint && bun run check:filenames",
    "hooks:install": "lefthook install",
    "hooks:pre-commit": "lefthook run pre-commit"
  },
  "dependencies": {
    "@mastra/core": "^1.17.0",
    "@mastra/evals": "^1.1.2",
    "@mastra/libsql": "^1.7.2",
    "@mastra/loggers": "^1.0.3",
    "@mastra/memory": "^1.10.0",
    "@mastra/observability": "^1.5.1",
    "@mastra/pg": "^1.8.3",
    "ai-sdk-ollama": "^3.8.0",
    "pino": "^10.3.1",
    "zod": "4"
  }
}
