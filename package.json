{
  "name": "stylistics-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "lefthook": "^2.1.4",
    "mastra": "^1.7.3",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "mastra dev",
    "build": "mastra build",
    "start": "mastra start",
    "lint": "eslint .",
    "lint:write": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:baseline": "bun scripts/baseline-db.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "validate": "bun run lint && bun run format:check && bun run typecheck",
    "hooks:install": "lefthook install",
    "hooks:pre-commit": "lefthook run pre-commit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@mastra/auth-better-auth": "^1.0.2",
    "@mastra/core": "^1.31.0",
    "@mastra/duckdb": "^1.2.0",
    "@mastra/evals": "^1.2.2",
    "@mastra/libsql": "^1.9.1",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.17.4",
    "@mastra/observability": "^1.11.0",
    "@mastra/pg": "^1.9.4",
    "@mastra/rag": "^2.2.1",
    "ai-sdk-ollama": "^3.8.0",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "4"
  }
}
