GOOGLE_GENERATIVE_AI_API_KEY=your-api-key
LMSTUDIO_API_KEY=123456789abcdef
OPENROUTER_API_KEY=your-openrouter-api-key
OPENCODE_API_KEY=your-opencode-api-key
# PostgreSQL
POSTGRES_USER=stylistics
POSTGRES_PASSWORD=stylistics_pass
POSTGRES_DB=stylistics_db
POSTGRES_PORT=5432
POSTGRES_URL=postgresql://stylistics:stylistics_pass@localhost:5432/stylistics_db

# --- Authentication (Better Auth + Google OAuth) ---
# Public backend URL used by Better Auth to build callbacks.
# Local Mastra dev normally runs on http://localhost:4111.
BETTER_AUTH_URL="http://localhost:4111"

# Generate a real secret for local/prod, for example:
# openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-generate-a-real-secret"

# Comma-separated origins allowed to call Better Auth from the Office add-in/taskpane.
BETTER_AUTH_TRUSTED_ORIGINS="https://localhost:3000"

# Google OAuth application credentials.
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
